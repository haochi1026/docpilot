APP_ENV=development
MYSQL_ROOT_PASSWORD=replace-with-a-local-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
JWT_SECRET=please-change-to-a-random-secret-longer-than-32-bytes
QUEUE_MODE=local
AI_MODE=local
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_API_KEY=ollama
AI_MODEL=qwen3.5:2b
AI_CONNECT_TIMEOUT_MS=2000
AI_READ_TIMEOUT_MS=180000
EMBEDDING_MODE=local
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSION=1024
EMBEDDING_CONNECT_TIMEOUT_MS=2000
EMBEDDING_READ_TIMEOUT_MS=60000
VECTOR_STORE_ENABLED=true
VECTOR_DB_PASSWORD=replace-with-a-random-vector-postgres-password
VECTOR_CANDIDATE_LIMIT=80
RETRIEVAL_MIN_SCORE=0.20
RETRIEVAL_MIN_LEXICAL_SCORE=0.05
RETRIEVAL_MIN_VECTOR_SCORE=0.45
RETRIEVAL_LEXICAL_WEIGHT=0.35
RETRIEVAL_VECTOR_WEIGHT=0.65
LEXICAL_CANDIDATE_LIMIT=160
RETRIEVAL_STRATEGY=HYBRID_RERANK
RERANK_CANDIDATE_LIMIT=24
RERANK_WEIGHT=0.25
CHUNK_MAX_TOKENS=480
CHUNK_OVERLAP_TOKENS=60
OCR_ENABLED=true
OCR_LANGUAGE=chi_sim+eng
OCR_MIN_PAGE_TEXT_CHARS=20
OCR_MAX_PAGES=100
OCR_TIMEOUT_SECONDS=60
OCR_MIN_CONFIDENCE=45
DOCUMENT_REVISION_RETENTION_COUNT=3
AGENT_INTERNAL_KEY=replace-with-a-random-internal-key
AGENT_INTERNAL_IDENTITY_SECRET=replace-with-a-distinct-hmac-identity-secret
AGENT_SERVICE_KEY=replace-with-a-different-random-service-key
AGENT_APPROVAL_SECRET=replace-with-a-random-approval-secret
AGENT_APPROVAL_TTL_MINUTES=15
AGENT_MODEL=qwen3.5:2b
AGENT_OLLAMA_BASE_URL=http://host.docker.internal:11434
AGENT_POSTGRES_DB=docpilot_agent
AGENT_POSTGRES_USER=docpilot_agent
AGENT_POSTGRES_PASSWORD=replace-with-a-random-postgres-password
CHECKPOINT_BACKEND=postgres
CHECKPOINT_RETENTION_DAYS=30
AGENT_MODEL_RUN_LIMIT=8
AGENT_TOOL_RUN_LIMIT=12
AGENT_CONTEXT_TOKEN_BUDGET=6000
AGENT_CONTEXT_SUMMARY_CHARS=1600
TOOL_MAX_RETRIES=2
TOOL_CIRCUIT_FAILURES=5
AGENTOPS_ENABLED=true
AGENTOPS_BASE_URL=http://host.docker.internal:18100
AGENTOPS_API_KEY=agentops-local-key
AGENTOPS_IDENTITY_TOKEN=
AGENTOPS_IDENTITY_TOKEN_SECRET=
AGENTOPS_IDENTITY_SUBJECT=docpilot-agent
AGENTOPS_IDENTITY_TENANT=default
AGENTOPS_IDENTITY_ROLE=OPERATOR
AGENTOPS_IDENTITY_ISSUER=docpilot-agent
AGENTOPS_IDENTITY_AUDIENCE=agentops-hub
AGENTOPS_IDENTITY_KEY_ID=v1
TRACE_CAPTURE_CONTENT=false
AGENTOPS_GOVERNANCE_ENABLED=false
CHECKPOINT_CLEANUP_INTERVAL_SECONDS=21600
INFERENCE_LEASE_SECONDS=240
INFERENCE_LOCAL_FALLBACK=true
OTEL_SERVICE_NAME=docpilot-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
